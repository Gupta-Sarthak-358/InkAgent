# Environment Configuration

# Copy this file to .env and fill in your API keys

# Gemini API Key
GEMINI_API_KEY=

# OpenRouter API Key
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=
OPENROUTER_REASONING=true
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=InkAgent

# Demo Mode (set to true for local-first execution)
INKAGENT_DEMO_MODE=true

# Local Model Path Override (optional)
# LOCAL_MODEL_ROOT=/path/to/models

# Python Path for local model inference
# PYTHON_PATH=/path/to/venv/bin/python3
